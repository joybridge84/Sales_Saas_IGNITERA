generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Enums
// --------------------------------------

enum Role {
  ADMIN
  SALES_MANAGER
  SALES
  DELIVERY
  VIEWER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  ARCHIVED
}

enum DealType {
  EC_IMPROVEMENT
  LP_CREATION
  APP_DEV
  PROOF_INFRA_POC
}

enum Stage {
  PROSPECTING
  DISCOVERY
  QUALIFIED
  PROPOSAL
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  DM
  NOTE
  PROPOSAL_SENT
  QUOTE_SENT
}

// --------------------------------------
// Models
// --------------------------------------

model User {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique @db.VarChar(255)
  name       String   @db.VarChar(100)
  role       Role     @default(SALES)
  teamId     String?  @map("team_id") @db.Uuid
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  team       Team?    @relation(fields: [teamId], references: [id])
  
  // Relations: Owner of various entities
  ownedLeads         Lead[]        @relation("LeadOwner")
  ownedAccounts      Account[]     @relation("AccountOwner")
  ownedContacts      Contact[]     @relation("ContactOwner")
  ownedOpportunities Opportunity[] @relation("OpportunityOwner")
  assignedTasks      Task[]        @relation("TaskAssignee")
  createdTasks       Task[]        @relation("TaskCreator")
  activities         Activity[]    @relation("ActivityCreator")
  quotes             Quote[]       @relation("QuoteCreator")
  handoffsOwned      Handoff[]     @relation("HandoffInternalOwner")
  handoffsCreated    Handoff[]     @relation("HandoffCreator")
  notifications      Notification[]

  @@map("users")
}

model Team {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  users     User[]

  @@map("teams")
}

model Lead {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName         String     @map("company_name") @db.VarChar(255)
  websiteUrl          String?    @map("website_url") @db.VarChar(500)
  industry            String?    @db.VarChar(100)
  companySize         String?    @map("company_size") @db.VarChar(50)
  region              String?    @db.VarChar(100)
  source              String     @db.VarChar(50)
  status              LeadStatus @default(NEW)
  fitScore            Int        @default(0) @map("fit_score")
  painHypothesis      String?    @map("pain_hypothesis") @db.Text
  firstContactDueAt   DateTime?  @map("first_contact_due_at") @db.Timestamptz
  lastContactedAt     DateTime?  @map("last_contacted_at") @db.Timestamptz
  ownerUserId         String     @map("owner_user_id") @db.Uuid
  convertedAccountId  String?    @map("converted_account_id") @db.Uuid
  convertedContactId  String?    @map("converted_contact_id") @db.Uuid
  convertedOppId      String?    @map("converted_opportunity_id") @db.Uuid
  notes               String?    @db.Text
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?  @map("deleted_at") @db.Timestamptz

  owner               User       @relation("LeadOwner", fields: [ownerUserId], references: [id])
  tasks               Task[]
  activities          Activity[]
  proofAssets         ProofAsset[]
  opportunities       Opportunity[]

  @@map("leads")
}

model Account {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  legalName           String   @map("legal_name") @db.VarChar(255)
  displayName         String   @map("display_name") @db.VarChar(255)
  websiteUrl          String?  @map("website_url") @db.VarChar(500)
  industry            String?  @db.VarChar(100)
  companySize         String?  @map("company_size") @db.VarChar(50)
  region              String?  @db.VarChar(100)
  ecFlag              Boolean  @default(false) @map("ec_flag")
  adsFlag             Boolean  @default(false) @map("ads_flag")
  engineeringTeamFlag Boolean  @default(false) @map("engineering_team_flag")
  hiringFlag          Boolean  @default(false) @map("hiring_flag")
  note                String?  @db.Text
  ownerUserId         String   @map("owner_user_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz

  owner               User            @relation("AccountOwner", fields: [ownerUserId], references: [id])
  contacts            Contact[]
  opportunities       Opportunity[]
  tasks               Task[]
  activities          Activity[]

  @@map("accounts")
}

model Contact {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId          String   @map("account_id") @db.Uuid
  name               String   @db.VarChar(100)
  department         String?  @db.VarChar(100)
  title              String?  @db.VarChar(100)
  email              String?  @db.VarChar(255)
  phone              String?  @db.VarChar(50)
  linkedinUrl        String?  @map("linkedin_url") @db.VarChar(500)
  xUrl               String?  @map("x_url") @db.VarChar(500)
  influenceLevel     String   @default("unknown") @map("influence_level") @db.VarChar(20)
  relationshipStatus String   @default("new") @map("relationship_status") @db.VarChar(20)
  note               String?  @db.Text
  ownerUserId        String   @map("owner_user_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  account            Account  @relation(fields: [accountId], references: [id])
  owner              User     @relation("ContactOwner", fields: [ownerUserId], references: [id])
  opportunities      Opportunity[] @relation("PrimaryContact")
  activities         Activity[]

  @@map("contacts")
}

model Opportunity {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId         String   @map("account_id") @db.Uuid
  primaryContactId  String?  @map("primary_contact_id") @db.Uuid
  title             String   @db.VarChar(255)
  dealType          DealType @map("deal_type")
  stage             Stage    @default(PROSPECTING)
  amount            Decimal? @db.Decimal(12, 0)
  currency          String   @default("JPY") @db.VarChar(10)
  probability       Int      @default(0)
  expectedCloseDate DateTime? @map("expected_close_date") @db.Date
  painSummary       String?  @map("pain_summary") @db.Text
  solutionSummary   String?  @map("solution_summary") @db.Text
  nextAction        String?  @map("next_action") @db.Text
  nextActionDueAt   DateTime? @map("next_action_due_at") @db.Timestamptz
  lossReason        String?  @map("loss_reason") @db.VarChar(100)
  competitorName    String?  @map("competitor_name") @db.VarChar(255)
  sourceLeadId      String?  @map("source_lead_id") @db.Uuid
  ownerUserId       String   @map("owner_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  closedAt          DateTime? @map("closed_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  account           Account         @relation(fields: [accountId], references: [id])
  primaryContact    Contact?        @relation("PrimaryContact", fields: [primaryContactId], references: [id])
  owner             User            @relation("OpportunityOwner", fields: [ownerUserId], references: [id])
  lead              Lead?           @relation(fields: [sourceLeadId], references: [id], onDelete: Cascade)
  activities        Activity[]
  tasks             Task[]
  quotes            Quote[]
  handoff           Handoff?
  proofAssets       OpportunityProofAsset[]

  @@map("opportunities")
}

model Activity {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId     String?      @map("opportunity_id") @db.Uuid
  leadId            String?      @map("lead_id") @db.Uuid
  accountId         String?      @map("account_id") @db.Uuid
  contactId         String?      @map("contact_id") @db.Uuid
  activityType      ActivityType @map("activity_type")
  subject           String       @db.VarChar(255)
  detail            String?      @db.Text
  outcome           String?      @db.VarChar(50)
  happenedAt        DateTime     @map("happened_at") @db.Timestamptz
  createdByUserId   String       @map("created_by_user_id") @db.Uuid
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz

  opportunity       Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  lead              Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  account           Account?     @relation(fields: [accountId], references: [id])
  contact           Contact?     @relation(fields: [contactId], references: [id])
  creator           User         @relation("ActivityCreator", fields: [createdByUserId], references: [id])

  @@map("activities")
}

model Task {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId          String?    @map("lead_id") @db.Uuid
  opportunityId   String?    @map("opportunity_id") @db.Uuid
  accountId       String?    @map("account_id") @db.Uuid
  title           String     @db.VarChar(255)
  description     String?    @db.Text
  status          TaskStatus @default(OPEN)
  priority        String     @default("medium") @db.VarChar(20)
  dueAt           DateTime?  @map("due_at") @db.Timestamptz
  assignedUserId  String     @map("assigned_user_id") @db.Uuid
  createdByUserId String     @map("created_by_user_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  completedAt     DateTime?  @map("completed_at") @db.Timestamptz

  lead            Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  account         Account?     @relation(fields: [accountId], references: [id])
  assignee        User         @relation("TaskAssignee", fields: [assignedUserId], references: [id])
  creator         User         @relation("TaskCreator", fields: [createdByUserId], references: [id])

  @@map("tasks")
}

model OfferTemplate {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(100)
  dealType            DealType @map("deal_type")
  targetIndustry      String?  @map("target_industry") @db.VarChar(100)
  painPattern         String   @map("pain_pattern") @db.Text
  proposalTemplate    String   @map("proposal_template") @db.Text
  defaultPriceMin     Decimal? @map("default_price_min") @db.Decimal(12, 0)
  defaultPriceMax     Decimal? @map("default_price_max") @db.Decimal(12, 0)
  defaultDeliveryDays Int?     @map("default_delivery_days")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("offer_templates")
}

model Quote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId   String   @map("opportunity_id") @db.Uuid
  version         Int      @default(1)
  title           String   @db.VarChar(255)
  amount          Decimal  @db.Decimal(12, 0)
  taxIncluded     Boolean  @default(false) @map("tax_included")
  scope           String   @db.Text
  deliveryTerm    String?  @map("delivery_term") @db.Text
  maintenanceTerm String?  @map("maintenance_term") @db.Text
  status          String   @default("draft") @db.VarChar(20) // draft, sent, accepted, rejected
  sentAt          DateTime? @map("sent_at") @db.Timestamptz
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  opportunity     Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  creator         User        @relation("QuoteCreator", fields: [createdByUserId], references: [id])

  @@map("quotes")
}

model Handoff {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  opportunityId       String   @unique @map("opportunity_id") @db.Uuid
  projectGoal         String   @map("project_goal") @db.Text
  deliverables        String   @db.Text
  successKpi          String?  @map("success_kpi") @db.Text
  risks               String?  @db.Text
  clientContext       String?  @map("client_context") @db.Text
  internalOwnerUserId String?  @map("internal_owner_user_id") @db.Uuid
  dueDate             DateTime? @map("due_date") @db.Date
  status              String   @default("draft") @db.VarChar(20) // draft, ready, handed_off
  createdByUserId     String   @map("created_by_user_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  opportunity         Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  internalOwner       User?       @relation("HandoffInternalOwner", fields: [internalOwnerUserId], references: [id])
  creator             User        @relation("HandoffCreator", fields: [createdByUserId], references: [id])

  @@map("handoffs")
}

model ProofAsset {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String   @db.VarChar(255)
  assetType    String   @map("asset_type") @db.VarChar(30)
  dealType     DealType @map("deal_type")
  industry     String?  @db.VarChar(100)
  url          String?  @db.VarChar(500)
  summary      String   @db.Text
  impactMetric String?  @map("impact_metric") @db.Text
  isPublic     Boolean  @default(false) @map("is_public")
  leadId       String?  @map("lead_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  lead          Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunities OpportunityProofAsset[]

  @@map("proof_assets")
}

model OpportunityProofAsset {
  opportunityId String @map("opportunity_id") @db.Uuid
  proofAssetId  String @map("proof_asset_id") @db.Uuid

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  proofAsset    ProofAsset  @relation(fields: [proofAssetId], references: [id])

  @@id([opportunityId, proofAssetId])
  @@map("opportunity_proof_assets")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(255)
  body      String?  @db.Text
  linkUrl   String?  @map("link_url") @db.VarChar(500)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(50)
  entityId    String   @map("entity_id") @db.Uuid
  action      String   @db.VarChar(30)
  beforeJson  Json?    @map("before_json")
  afterJson   Json?    @map("after_json")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_logs")
}
